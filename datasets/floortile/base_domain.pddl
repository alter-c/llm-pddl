(define (domain floortile)
  (:requirements :typing)
  (:types robot tile color - object)
  (:predicates 	
    (robot-at ?r ?x)
    (up ?x ?y)
    (down ?x ?y)
    (right ?x ?y)
    (left ?x ?y)
    (clear ?x)
    (painted ?x ?c)
    (robot-has ?r ?c)
    (available-color ?c)
    (free-color ?r)
  )

  (:action change-color) 
  (:action paint-up)
  (:action paint-down)
  (:action up)
  (:action down)
  (:action right)
  (:action left)
)

