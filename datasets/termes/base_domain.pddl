(define (domain termes)
  (:requirements :typing :negative-preconditions)
  (:types numb position - object)
  (:predicates
    (height ?p ?h)
    (at ?p)
    (has-block)
    (SUCC ?n1 ?n2)
    (NEIGHBOR ?p1 ?p2)
    (IS-DEPOT ?p)
  )
  (:action move)
  (:action move-up)
  (:action move-down)
  (:action place-block)
  (:action remove-block)
  (:action create-block)
  (:action destroy-block)
)